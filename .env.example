# =============================================================
# .env.example
# Environment variable template for InvestSim
# =============================================================
#
# HOW TO USE:
#   1. Copy this file to .env in the repository root
#   2. Replace every placeholder value with your real values
#   3. NEVER commit .env to version control
#   4. .env is already listed in .gitignore
#
# For GitHub Actions deployment, each variable below must also
# be added as a Secret in:
# GitHub repository → Settings → Secrets and variables → Actions
# =============================================================

# ── Firebase Configuration ────────────────────────────────────
# Obtain these values from:
# Firebase Console → Project Settings → Your apps → investsim-web → SDK setup

FIREBASE_API_KEY=your-firebase-api-key-here
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id-here
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id-here
FIREBASE_APP_ID=your-app-id-here

# ── Financial Modeling Prep API ───────────────────────────────
# Obtain from: https://financialmodelingprep.com/developer/docs
# Development: Basic tier (free, end-of-day data, 250 calls/day)
# Classroom:   Premium tier ($59/month, intraday delayed data)
# Note: This key is visible in client-side browser requests.
# Restrict it by domain in the FMP dashboard after deployment.

FMP_API_KEY=your-fmp-api-key-here

# ── Owner Account Setup ───────────────────────────────────────
# Used ONLY by scripts/setup-owner.js — the one-time owner
# account creation script. Never used by the application itself.
# WARNING: Never commit real values for these two variables.
# WARNING: Never add these two to GitHub Actions Secrets.
# Delete these values from your local .env after running
# scripts/setup-owner.js in task 0.7.

OWNER_EMAIL=your-owner-email-here
OWNER_PASSWORD=your-owner-password-here